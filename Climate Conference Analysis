-- Getting a sample size of the tables to examine tables and columns.

SELECT * FROM vips LIMIT 25;
SELECT * FROM reservations LIMIT 25;
SELECT * FROM events LIMIT 25;
SELECT * FROM hotels LIMIT 25;

-- 1. [LEFT JOIN] List all the VIPs (last and first name) and any panels they are presenting at.

SELECT 
	vips.last_name, 
	vips.first_name, 
	events.event_name
FROM vips

LEFT JOIN events
ON vips.event = events.event_id;

-- 2. [INNER JOIN] List the VIPs that have not RSVPd to the dinner.

SELECT
	vips.last_name, 
	vips.first_name, 
	reservations.dinner_rsvp
FROM vips

JOIN reservations
ON vips.member_id = reservations.member_id

WHERE reservations.dinner_rsvp = 0;

-- 3. [Multiple JOINs] Show the total number events being hosted at each hotel. Order by which hotel is hosting the most events.

SELECT 
	h.hotel_name, 
	COUNT(DISTINCT e.event_id) AS event_total
FROM vips v

JOIN reservations r
ON v.member_id = r.member_id

JOIN hotels h
ON r.hotel = h.hotel_id

JOIN events e
ON e.event_id = v.event

GROUP BY h.hotel_name
ORDER BY event_total DESC;

GROUP BY hotel_name;

-- 4. [SELF JOIN] Show the first and last name of the speakers that will be presenting and who will be providing the feedback to their presentation. 

SELECT 
	speaker.last_name AS speaker_last_name,
	speaker.first_name AS speaker_first_name,
	reviewer.last_name AS reviewer_last_name,
	reviewer.first_name AS reviewer_first_name
FROM vips speaker

JOIN vips reviewer
ON speaker.member_id = reviewer.provides_feedback_to;

-- 5. [Multiple JOINs] Show the VIPs who skipped the dinner RSVP, but are staying at the hotel where their event is hosted. Show the hotel and event being held.

SELECT
	v.last_name,
	v.first_name,
	e.event_name,
	h.hotel_name
FROM vips v

JOIN events e 
ON v.event = e.event_id

JOIN reservations r
ON v.member_id = r.member_id

JOIN hotels h
ON r.hotel = h.hotel_id

WHERE r.dinner_rsvp = 0;

-- 6. [Multiple JOINs + LEFT JOIN] Show the hotel name and address for all VIPs that have been members since before 2002. Include their member ID, association, event name, and the year they became a member. Order by VIPs that have been in the longest. 

SELECT
	v.member_id,
	v.association,
    h.hotel_name,
    h.address,
    e.event_name,
    v.member_since
FROM vips v

JOIN reservations r
ON v.member_id = r.member_id

JOIN hotels h
ON r.hotel = h.hotel_id

LEFT JOIN events e
ON v.event = e.event_id

WHERE v.member_since < 2002
ORDER BY v.member_since ASC;
